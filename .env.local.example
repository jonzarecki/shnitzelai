# Required: at least one AI provider API key
OPENAI_API_KEY=sk-...          # Required if using OpenAI text or image models
# GOOGLE_API_KEY=              # Required if using Gemini or Imagen 4
# BFL_API_KEY=                 # Required if using Flux models

# AI model configuration (all optional, shown with defaults)
# TEXT_PROVIDER=openai         # openai | google
# TEXT_MODEL=gpt-4.1-mini      # model name within provider
# IMAGE_PROVIDER=openai        # openai | bfl | google
# IMAGE_MODEL=gpt-image-1.5    # model name within provider
# IMAGE_QUALITY=medium          # low | medium | high

# Cron configuration
CRON_SECRET=change-me-to-a-random-string
# CRON_SCHEDULE=0 */6 * * *   # every 6 hours

# Twitter/X posting (optional, for manual posting from admin)
# TWITTER_APP_KEY=
# TWITTER_APP_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
